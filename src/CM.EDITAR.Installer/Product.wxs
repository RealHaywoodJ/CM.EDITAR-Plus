<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="CM.EDITAR+"
           Manufacturer="CM.EDITAR+ Contributors"
           Version="1.3.0.0"
           UpgradeCode="A0000003-0000-0000-0000-000000000001"
           Scope="perUser"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of CM.EDITAR+ is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="Main" Title="CM.EDITAR+" Level="1">
      <ComponentGroupRef Id="UIPublishComponents" />
      <ComponentGroupRef Id="FileCreatorPublishComponents" />
      <ComponentGroupRef Id="ShortcutAndMarker" />
      <ComponentGroupRef Id="NewPlusRegistration" />
    </Feature>

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLDIR" Name="CM.EDITAR+">
        <Directory Id="UIDir" Name="UI" />
        <Directory Id="FCDir" Name="FileCreator" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="StartMenuShortcuts" Name="CM.EDITAR+" />
    </StandardDirectory>

    <!--
      WiX v4 <Files> element auto-harvests every file under the source directory into
      a ComponentGroup, including .dll, .deps.json, .runtimeconfig.json, native assets,
      and Avalonia resources required for framework-dependent .NET 8 publish output.
    -->
    <ComponentGroup Id="UIPublishComponents" Directory="UIDir">
      <Files Include="$(var.UIPublishDir)\**" />
    </ComponentGroup>

    <ComponentGroup Id="FileCreatorPublishComponents" Directory="FCDir">
      <Files Include="$(var.FileCreatorPublishDir)\**" />
    </ComponentGroup>

    <ComponentGroup Id="ShortcutAndMarker" Directory="INSTALLDIR">
      <Component Id="StartMenuShortcut" Directory="StartMenuShortcuts" Guid="A0000003-0000-0000-0000-000000000012">
        <Shortcut Id="StartMenuLink" Name="CM.EDITAR+"
                  Target="[UIDir]CM.EDITAR.UI.exe" WorkingDirectory="UIDir" />
        <RegistryValue Root="HKCU" Key="Software\CM.EDITAR+" Name="installed" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- Optional New+ submenu parent key registration (per-user, HKCU only) -->
    <ComponentGroup Id="NewPlusRegistration" Directory="INSTALLDIR">
      <Component Id="NewPlusRoot" Guid="A0000003-0000-0000-0000-000000000020">
        <RegistryKey Root="HKCU" Key="Software\Classes\CM.EDITAR.NewPlus">
          <RegistryValue Type="string" Name="(default)" Value="New+" KeyPath="yes" />
        </RegistryKey>
      </Component>
    </ComponentGroup>

    <!--
      Custom actions: capture an HKCU snapshot before file install, and restore it on
      uninstall. The FileCreator binary path is resolved through the FILECREATOREXE
      property (formatted from the install-time FCDir value) rather than a File-id
      binder, because <Files> generates non-stable harvested ids per build.
    -->
    <Property Id="FILECREATOREXE" Value="[FCDir]CM.EDITAR.FileCreator.exe" />
    <CustomAction Id="CreateInstallerSnapshot"
                  Property="FILECREATOREXE"
                  ExeCommand="--installer-snapshot"
                  Execute="deferred"
                  Impersonate="yes"
                  Return="ignore" />
    <CustomAction Id="RestoreInstallerSnapshot"
                  Property="FILECREATOREXE"
                  ExeCommand="--restore-installer-snapshot"
                  Execute="deferred"
                  Impersonate="yes"
                  Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="CreateInstallerSnapshot" After="InstallFiles" Condition="NOT Installed" />
      <Custom Action="RestoreInstallerSnapshot" Before="RemoveFiles" Condition="REMOVE=&quot;ALL&quot;" />
    </InstallExecuteSequence>

  </Package>
</Wix>
