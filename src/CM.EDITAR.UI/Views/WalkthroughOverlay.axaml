<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CM.EDITAR.UI.Views.WalkthroughOverlay">
  <Border Background="#CC000000">
    <Border Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="24" MaxWidth="520"
            HorizontalAlignment="Center" VerticalAlignment="Center" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1">
      <StackPanel Spacing="10">
        <TextBlock Text="Welcome to CM.EDITAR+" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
        <TextBlock TextWrapping="Wrap" Text="CM.EDITAR+ safely manages Windows Explorer's New menu. Every change is staged, snapshotted, and reversible. No system writes — HKCU only."/>
        <TextBlock TextWrapping="Wrap" Text="1. Browse discovered entries by category." Margin="0,8,0,0"/>
        <TextBlock TextWrapping="Wrap" Text="2. Stage edits. Use Preflight to review the dry-run."/>
        <TextBlock TextWrapping="Wrap" Text="3. Apply when satisfied — every batch is snapshotted and undoable."/>
        <Button Content="Got it" HorizontalAlignment="Right" Margin="0,12,0,0" Click="OnGotItClick"/>
      </StackPanel>
    </Border>
  </Border>
</UserControl>
