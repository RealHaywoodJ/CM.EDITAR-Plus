root = true

# =============================================================================
# Defaults for every file in the repo
# =============================================================================
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# =============================================================================
# C# / .NET — 4-space indent, file-scoped namespaces, var preferred
# =============================================================================
[*.{cs,csx,vb}]
indent_size = 4

# Prefer file-scoped namespace declarations
csharp_style_namespace_declarations = file_scoped:warning

# `var` for built-in and inferred types
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion

# Modern language features
csharp_prefer_braces = true:warning
csharp_style_expression_bodied_methods = false:none
csharp_new_line_before_open_brace = all
csharp_indent_case_contents = true
csharp_indent_switch_labels = true

# `this.` qualification — discouraged
dotnet_style_qualification_for_field = false:warning
dotnet_style_qualification_for_property = false:warning
dotnet_style_qualification_for_method = false:warning
dotnet_style_qualification_for_event = false:warning

[*.{csproj,vbproj,proj,props,targets}]
indent_size = 2

# =============================================================================
# Web / TS / JS — 2-space indent (matches the existing pnpm workspace)
# =============================================================================
[*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,md,html,css,scss}]
indent_size = 2

# =============================================================================
# PowerShell scripts
# =============================================================================
[*.{ps1,psm1,psd1}]
indent_size = 4

# =============================================================================
# Windows-specific files keep CRLF
# =============================================================================
[*.{cmd,bat}]
end_of_line = crlf

[*.sln]
indent_style = tab
end_of_line = crlf
